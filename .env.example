# =============================================================================
# PetCare Frontend — Variables de Entorno
# =============================================================================
# Copia este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# ⚠️  NUNCA subas .env.local ni .env.production al repositorio.
#     Para producción (Vercel/Render), configura las variables directamente
#     en el dashboard de la plataforma.
# =============================================================================


# -----------------------------------------------------------------------------
# 🔌 URL base del backend (Spring Boot)
# -----------------------------------------------------------------------------
# Desarrollo local:
#   VITE_API_URL=http://localhost:8088
#
# Producción en Render:
#   VITE_API_URL=https://tu-backend.onrender.com
#
# ⚠️  Sin barra final /
# ⚠️  DEBE empezar con VITE_ para que Vite lo exponga al cliente
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8088


# -----------------------------------------------------------------------------
# 📋 Dónde configurarlo en cada plataforma
# -----------------------------------------------------------------------------
# Vercel:
#   Dashboard → tu proyecto → Settings → Environment Variables
#   Agrega: VITE_API_URL = https://tu-backend.onrender.com
#
# Netlify:
#   Dashboard → tu sitio → Site settings → Environment variables
#
# Render (frontend):
#   Dashboard → tu servicio → Environment → Add Environment Variable
# -----------------------------------------------------------------------------
